# =============================================================
# Capillary Solution Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================

# ── App Config ────────────────────────────────────────────────
# Environment: development | production
NODE_ENV=development

# Port for the web server (default 3000)
PORT=3000

# Max tokens for agent response (increase for SDD generation)
MAX_AGENT_TOKENS=24000

# Confidence threshold below which agent escalates to SA (0-100)
ESCALATION_THRESHOLD=80

# ── Basic Auth (leave AUTH_PASS empty to disable) ─────────────
AUTH_USER=admin
AUTH_PASS=

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# --- Jira ---
JIRA_BASE_URL=https://capillarytech.atlassian.net
JIRA_EMAIL=krishnendu.chakraborty@capillarytech.com
JIRA_API_TOKEN=

# --- Confluence ---
CONFLUENCE_BASE_URL=https://capillarytech.atlassian.net/wiki
CONFLUENCE_API_TOKEN=

# --- Capillary Kapa Docs (optional — degrades gracefully if absent) ---
# Kapa MCP/REST endpoint for product documentation search
CAPILLARY_DOCS_MCP_URL=https://capdocumentation.mcp.kapa.ai
CAPILLARY_DOCS_MCP_TOKEN=

# --- Web Search (sitemap-guided, no external API needed) ---
# Defaults to https://docs.capillarytech.com/sitemap.xml if not set
WEB_SEARCH_SITEMAP_URL=https://docs.capillarytech.com/sitemap.xml
