# =============================================================
# Capillary Solution Agent — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================

# ── App Config ────────────────────────────────────────────────
# Environment: development | production
NODE_ENV=development

# Port for the web server (default 3000)
PORT=3000

# Max tokens for agent response (increase for SDD generation)
MAX_AGENT_TOKENS=24000

# Confidence threshold below which agent escalates to SA (0-100)
ESCALATION_THRESHOLD=80

# ── Auth (Phase I — multi-user) ───────────────────────────────
# Required: secret used to sign session cookies (any long random string)
SESSION_SECRET=change-me-to-a-long-random-secret

# Bootstrap: used ONCE to create the first admin user when data/users.json is empty.
# Remove or leave blank after first startup — not read again once a user exists.
BOOTSTRAP_ADMIN_EMAIL=admin@capillarytech.com
BOOTSTRAP_ADMIN_PASS=

# ── SSO — Google OAuth2 (optional) ───────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://slack-solution-agent-production.up.railway.app/auth/google/callback

# ── SSO — Microsoft OAuth2 (optional) ────────────────────────
# Create app at https://portal.azure.com → Azure Active Directory → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://slack-solution-agent-production.up.railway.app/auth/microsoft/callback

# Domain allowed to sign in via SSO (default: capillarytech.com)
ALLOWED_EMAIL_DOMAIN=capillarytech.com

# ── Store Backend ──────────────────────────────────────────────
# Storage backend: "json" (flat files, default) or "mongodb"
STORE_BACKEND=json

# MongoDB connection string (required only when STORE_BACKEND=mongodb)
# MONGODB_URI=mongodb://localhost:27017

# Alternative to MONGODB_URI: provide Atlas credentials and the connection string
# will be composed automatically using the template:
# mongodb+srv://{username}:{password}@solution-agent.ikuk2cg.mongodb.net/?appName=solution-agent
# MONGODB_USERNAME=
# MONGODB_PASSWORD=

# MongoDB database name (default: capillary_agent)
# MONGODB_DB_NAME=capillary_agent

# ── Context Compaction ────────────────────────────────────────
# Token count threshold above which older messages are summarised (default: 60000)
# CONTEXT_COMPACTION_THRESHOLD=60000

# ── Parallel Research Agents ──────────────────────────────────
# Per-agent timeout in milliseconds (default: 15000)
# RESEARCH_AGENT_TIMEOUT_MS=15000

# Max tool-call turns per research agent (default: 5)
# RESEARCH_AGENT_MAX_TURNS=5

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Jira ──────────────────────────────────────────────────────
JIRA_BASE_URL=https://capillarytech.atlassian.net
JIRA_EMAIL=krishnendu.chakraborty@capillarytech.com
JIRA_API_TOKEN=

# ── Confluence ────────────────────────────────────────────────
CONFLUENCE_BASE_URL=https://capillarytech.atlassian.net/wiki
CONFLUENCE_API_TOKEN=

# ── Capillary Kapa Docs (optional — degrades gracefully if absent) ──
CAPILLARY_DOCS_MCP_URL=https://capdocumentation.mcp.kapa.ai
CAPILLARY_DOCS_MCP_TOKEN=

# ── Web Search (sitemap-guided, no external API needed) ───────
# Defaults to https://docs.capillarytech.com/sitemap.xml if not set
WEB_SEARCH_SITEMAP_URL=https://docs.capillarytech.com/sitemap.xml

# ── LangSmith observability (Phase I-4, optional) ─────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to enable tracing; omit to disable silently.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_PROJECT=capillary-solution-agent
